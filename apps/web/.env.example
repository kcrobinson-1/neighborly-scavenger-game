# Remote or hosted Supabase project values for backend-backed development.
# If you are working without Supabase, leave these unset and explicitly enable
# the offline fallback with `VITE_ENABLE_LOCAL_PROTOTYPE_FALLBACK=true`.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key

# Optional explicit fallback for offline-only frontend work.
# Leave this false during normal remote-Supabase integration testing.
VITE_ENABLE_LOCAL_PROTOTYPE_FALLBACK=false
