{
  "name": "neighborly-scavenger-game",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @neighborly/web run dev",
    "dev:web:local": "npm --workspace @neighborly/web run dev -- --host 127.0.0.1 --port 4173",
    "build:web": "npm --workspace @neighborly/web run build",
    "lint": "eslint apps shared supabase scripts",
    "ui:review:capture": "node scripts/ui-review/capture-ui-review.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "playwright": "^1.59.1",
    "typescript-eslint": "^8.58.0"
  }
}
